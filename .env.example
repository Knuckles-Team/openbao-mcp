# ==============================================================================
# OpenBao Secrets MCP Server Environment Variables Configuration
# ==============================================================================

# --- OpenBao Server Endpoint & Address Configuration ---
# The primary URL of the OpenBao server.
OPENBAO_URL=http://127.0.0.1:8200

# Root or service account access token.
OPENBAO_TOKEN=bao_root_token

# Fallback address aliases for OpenBao / Vault endpoints.
BAO_ADDR=http://127.0.0.1:8200
VAULT_ADDR=http://127.0.0.1:8200

# --- Advanced Username/Password Auth Configuration ---
# Alternative base URL fallback for user-level client endpoints.
OPENBAO_MCP_BASE_URL=http://127.0.0.1:8200

# Client credentials for user authentication methods.
OPENBAO_MCP_USERNAME=
OPENBAO_MCP_PASSWORD=

# Enable/disable SSL/TLS certificate verification (True or False).
OPENBAO_MCP_SSL_VERIFY=True

# --- Action-Routed Tool Control Flags ---
# Set to True/False to enable or disable specific tool categories in the MCP server.
SECRETSTOOL=True
SYSTOOL=True
AUTHTOOL=True
SSHTOOL=True
